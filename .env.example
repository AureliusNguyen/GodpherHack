# Shared demo config. Copy to .env (which is gitignored) for local
# overrides. Secrets here are demo-only and will be rotated post-demo.
#
# All vars are optional individually. Behavior:
#   - LLM provider: at least one of these must resolve, or the CLI
#     prompts you to pick one and paste a key manually.
#   - Hub auth: all three GitHub OAuth + JWT_SECRET must be set
#     together to enable real auth, OR set ALLOW_ANONYMOUS_HUB=true
#     to run an open Hub. Hub refuses to start without one or the
#     other.

# --- LLM providers (set at least one) ---
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Ollama lives on the lab machine; agent host points at it remotely.
OLLAMA_BASE_URL=http://134.84.145.128:11434
LITELLM_BASE_URL=
LITELLM_API_KEY=

# --- Hub: where the Hub serves and what clients use to reach it ---
# For the demo: Hub runs on the lab machine at this IP, both teammates
# point their CLIs here. Change to http://localhost:3000 for local-only
# development (and update the GitHub OAuth callback to match).
HUB_BASE_URL=http://134.84.145.128:3000

# --- Hub auth (GitHub OAuth + JWT) ---
# Register an OAuth App at https://github.com/settings/developers
# Callback URL must be: <HUB_BASE_URL>/auth/github/callback
GITHUB_CLIENT_ID=Ov23ligCjAupdJ7Tx0g0
GITHUB_CLIENT_SECRET=79796961330ddb3876d52fef812425046a15b57e
# Generate a real one before deploy: openssl rand -hex 32
JWT_SECRET=demo-secret-rotate-after-presentation-do-not-ship

# Set to "true" to skip auth and run an open Hub. Useful for hermetic
# load testing and the smoke script. Otherwise leave blank.
ALLOW_ANONYMOUS_HUB=

# --- Hub: writeup storage (Pinecone) ---
PINECONE_API_KEY=
PINECONE_INDEX_NAME=ctf-writeups
